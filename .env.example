# Backend
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
VLM_MODEL=gpt-5.4-mini-2026-03-17
PROMPT_EXPANDER_MODEL=gpt-5.4-mini-2026-03-17

# Initial image generation (Gemini 3 Pro Image / nano-banana-pro)
GEMINI_API_KEY=sk-replace-me
GEMINI_BASE_URL=https://api.nuwaflux.com
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_ASPECT_RATIO=1:1
GEMINI_IMAGE_SIZE=1K

IP_COMPOSER_URL=http://localhost:12100

# Frontend (also copy to frontend/.env.local)
NEXT_PUBLIC_API_BASE=http://localhost:8000
